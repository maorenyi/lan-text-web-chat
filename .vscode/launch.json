{
  "configurations": [
    {
      "name": "main.py",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/server/main.py",
      "console": "integratedTerminal"
    },
    {
      "name": "uvicorn",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "server.app:app",
        "--host",
        "0.0.0.0",
        "--port",
        "12345",
        "--reload"
      ],
      "console": "integratedTerminal"
    }
  ]
}
